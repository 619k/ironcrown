# IronCrown API — Environment Variables
# Copy this file to .env and fill in your values

# ── Database ────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ironcrown"

# ── JWT ─────────────────────────────────────────────
JWT_SECRET="change-me-to-a-very-long-random-secret-256bit"
JWT_REFRESH_SECRET="another-very-long-random-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ── Plugin Bridge ────────────────────────────────────
PLUGIN_API_KEY="ironcrown-plugin-secret-key-change-me"
# Comma-separated list of allowed plugin server IPs
BRIDGE_ALLOWED_IPS="127.0.0.1,::1"
# Max bridge requests per minute per IP
BRIDGE_RATE_LIMIT_PER_MINUTE=20

# ── Redis (optional) ─────────────────────────────────
# Leave empty to use in-memory node-cache
REDIS_URL=""

# ── Discord Webhook ──────────────────────────────────
DISCORD_WEBHOOK_URL=""

# ── Logging ──────────────────────────────────────────
LOG_LEVEL="info"
